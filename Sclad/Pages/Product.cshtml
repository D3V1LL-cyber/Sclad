@page
@model Склад.Pages.ProductModel
@{
    ViewData["Title"] = Model.Product?.ProductId == 0 ? "Добавить новый товар" : "Редактировать товар";
}

<div class="container">
    <h2 class="mb-4">@ViewData["Title"]</h2>

    <form method="post">
        <input type="hidden" asp-for="Product.ProductId" />

        <div class="mb-3">
            <label asp-for="Product.Name" class="form-label">Название</label>
            <input asp-for="Product.Name" type="text" class="form-control" />
            <span asp-validation-for="Product.Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Product.Price" class="form-label">Цена</label>
            <input asp-for="Product.Price" type="number" class="form-control" step="0.01" />
            <span asp-validation-for="Product.Price" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Product.Quantity" class="form-label">Количество</label>
            <input asp-for="Product.Quantity" type="number" class="form-control" />
            <span asp-validation-for="Product.Quantity" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Product.CategoryId" class="form-label">Категория</label>
            <select asp-for="Product.CategoryId" class="form-control" asp-items="Model.CategoryList">
                <option value="">Выберите категорию</option>
            </select>
            <span asp-validation-for="Product.CategoryId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Product.SupplierId" class="form-label">Поставщик</label>
            <select asp-for="Product.SupplierId" class="form-control" asp-items="Model.SupplierList">
                <option value="">Выберите поставщика</option>
            </select>
            <span asp-validation-for="Product.SupplierId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-page="ProductsList" class="btn btn-secondary">Отмена</a>
    </form>
</div>